#!/bin/bash
set -e

PACKAGE_NAME="osoyoo-dsi-panel"
PACKAGE_VERSION="1.0"

case "$1" in
    remove|upgrade|deconfigure)
        # Unload modules if loaded
        modprobe -r osoyoo-panel-dsi 2>/dev/null || true
        modprobe -r osoyoo-panel-regulator 2>/dev/null || true

        # Remove from DKMS
        if dkms status -m ${PACKAGE_NAME} -v ${PACKAGE_VERSION} | grep -q "installed"; then
            dkms remove -m ${PACKAGE_NAME} -v ${PACKAGE_VERSION} --all || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
